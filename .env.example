# Prisma — Postgres (Neon recommended for both dev and prod).
# Local dev: create a Neon branch or run Postgres in Docker; SQLite is no longer supported.
# DATABASE_URL must be the *pooled* (pgbouncer) connection string in production.
DATABASE_URL="postgresql://user:pass@host-pooler.region.neon.tech/dbname?sslmode=require"
# DIRECT_URL is the *unpooled* connection string. Used by `prisma migrate` / `prisma db push`.
DIRECT_URL="postgresql://user:pass@host.region.neon.tech/dbname?sslmode=require"

# Auth (https://authjs.dev)
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Next.js auth URL (e.g. http://localhost:3000 in dev, https://verdantplan.com in prod)
AUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com/)
# Use OAuth credentials from the same Cloud project, and enable “Google Calendar API”
# there (APIs & Services → Library), or calendar sync returns 403 accessNotConfigured.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# OpenAI — used for plan generation, NL schedule edits, Fern chat, and lesson notes.
# Without it, plan generation falls back to a static template and NL edits are disabled.
OPENAI_API_KEY=""

# YouTube Data API v3 — required when you paste a YouTube *playlist* URL as a starting resource
# (each lesson session gets the next video in the playlist). Create a key in Google Cloud Console
# and enable “YouTube Data API v3” for the project.
YOUTUBE_API_KEY=""

# Hugging Face — required for natural-language schedule edits (Inference Providers router)
# Token needs permission: “Make calls to Inference Providers” (fine-grained token).
HF_API_TOKEN=""
# Chat model id (see https://huggingface.co/docs/api-inference )
HF_SCHEDULE_MODEL="meta-llama/Meta-Llama-3-8B-Instruct"
# Optional override; default is OpenAI-compatible router chat completions
# HF_CHAT_COMPLETIONS_URL="https://router.huggingface.co/v1/chat/completions"
# Max completion tokens (schedule JSON). Increase if responses truncate mid-JSON.
HF_SCHEDULE_MAX_NEW_TOKENS="4096"
